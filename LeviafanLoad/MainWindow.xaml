<Window x:Class="LeviafanLoad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="LeviafanLoad | v1.1.0" Height="910" Width="1360"
        WindowStartupLocation="CenterScreen"
        Background="#121212" FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#121212"/>
        <SolidColorBrush x:Key="PanelDark" Color="#1E1E24"/>
        <SolidColorBrush x:Key="AccentColor" Color="#6366F1"/>
        <SolidColorBrush x:Key="AccentHover" Color="#4F46E5"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#374151"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelDark}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BorderColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="10,5" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="◀" Width="40" Margin="0,0,5,0" x:Name="btnBack"/>
                    <Button Content="▶" Width="40" Margin="0,0,15,0" x:Name="btnForward"/>
                    <Button Content="🔄" Width="40" Margin="0,0,15,0" x:Name="btnRefresh"/>
                </StackPanel>
                <TextBox Grid.Column="1" x:Name="txtUrl" FontSize="14" Text="https://"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Button Content="Перейти" x:Name="btnGo" Width="80"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="Black" Margin="10">
                <wv2:WebView2 x:Name="webView"/>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelDark}" CornerRadius="8" Margin="0,10,10,10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TabControl Grid.Row="0">
                        <TabItem Header="НАСТРОЙКИ">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                <StackPanel>

                                    <TextBlock Text="Путь сохранения:" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,5"/>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="txtFolder" IsReadOnly="True" Margin="0,0,5,0"/>
                                        <Button Grid.Column="1" Content="..." Width="35" x:Name="btnFolder"/>
                                    </Grid>

                                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Margin="0,5,0,15"/>

                                    <CheckBox x:Name="chkBatchMode" Content="Пакетная загрузка (Несколько глав)" FontWeight="Bold"/>
                                    <StackPanel Margin="20,10,0,15" IsEnabled="{Binding ElementName=chkBatchMode, Path=IsChecked}">
                                        <TextBlock Text="Шаблон URL (используй {i} для номера):" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                        <TextBox x:Name="txtBatchUrl" Text="https://site.com/manga/chapter-{i}/" Margin="0,2,0,10"/>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                                <TextBlock Text="От ({i}):" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                                <TextBox x:Name="txtBatchStart" Text="1"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                                                <TextBlock Text="До ({i}):" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                                <TextBox x:Name="txtBatchEnd" Text="10"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" x:Name="chkBatchAuto" Content="Авто до ошибки" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                        </Grid>

                                    </StackPanel>

                                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Margin="0,5,0,15"/>

                                    <TextBlock Text="Имя результата (папка/zip, используй {i}):" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                    <TextBox x:Name="txtOutputNamePattern" Text="Chapter_{i}" Margin="0,2,0,10"/>

                                    <TextBlock Text="Префикс страниц:" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                    <TextBox x:Name="txtPagePrefix" Text="Page_" Margin="0,2,0,0"/>

                                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Margin="0,5,0,15"/>

                                    <TextBlock Text="ОБРАБОТКА ИЗОБРАЖЕНИЙ" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <CheckBox x:Name="chkZip" Content="Упаковать в .zip (название из поля выше)" FontWeight="Bold" Margin="0,5,0,5"/>

                                    <RadioButton x:Name="radNoCombine" Content="Не объединять (оставить как есть)" IsChecked="True" GroupName="CombineGroup"/>
                                    <RadioButton x:Name="radCombineParts" Content="Объединить в рулон и нарезать на N частей" GroupName="CombineGroup"/>
                                    <StackPanel Margin="25,2,0,10" IsEnabled="{Binding ElementName=radCombineParts, Path=IsChecked}">
                                        <TextBlock Text="Количество частей:" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                        <TextBox x:Name="txtPartsCount" Text="10" Width="60" HorizontalAlignment="Left"/>
                                    </StackPanel>

                                    <RadioButton x:Name="radCombineHeight" Content="Объединить в рулон и нарезать по высоте" GroupName="CombineGroup"/>
                                    <StackPanel Margin="25,2,0,15" IsEnabled="{Binding ElementName=radCombineHeight, Path=IsChecked}">
                                        <TextBlock Text="Высота части (px):" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                        <TextBox x:Name="txtSliceHeight" Text="4000" Width="60" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="ПОДРОБНЫЕ ЛОГИ">
                            <ListBox x:Name="lstLog" Background="#121212" Foreground="{StaticResource TextSecondary}" BorderBrush="{StaticResource BorderColor}" Margin="0,10,0,0">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="5,3"/>
                                    </Style>
                                </ListBox.Resources>
                            </ListBox>
                        </TabItem>

                        <TabItem Header="ИНФО И F.A.Q.">
                            <StackPanel Margin="10,15,10,0">
                                <TextBlock Text="LeviafanLoad" Foreground="{StaticResource AccentColor}" FontSize="28" FontWeight="Bold"/>
                                <TextBlock Text="Версия 1.0.0" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,0,0,20"/>

                                <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="15" Margin="0,0,0,8">
                                    <Run Text="Разработчик: " Foreground="{StaticResource TextSecondary}"/>
                                    <Run Text="Левиафан"/>
                                </TextBlock>

                                <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="15" Margin="0,0,0,8">
                                    <Run Text="Связь (Telegram): " Foreground="{StaticResource TextSecondary}"/>
                                    <Hyperlink RequestNavigate="Hyperlink_RequestNavigate" NavigateUri="https://t.me/leviafanTR" Foreground="{StaticResource AccentColor}">
                                        @leviafanTR
                                    </Hyperlink>
                                </TextBlock>

                                <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="15" Margin="0,0,0,20">
                                    <Run Text="Создано при поддержке: " Foreground="{StaticResource TextSecondary}"/>
                                    <Hyperlink RequestNavigate="Hyperlink_RequestNavigate" NavigateUri="https://mangalair.org" Foreground="{StaticResource AccentColor}">
                                        MangaLair.org
                                    </Hyperlink>
                                </TextBlock>

                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Margin="0,5,0,25"/>

                                <TextBlock Text="ОБНОВЛЕНИЯ" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                                <Button x:Name="btnUpdate" Content="ПРОВЕРИТЬ ОБНОВЛЕНИЯ" Width="220" HorizontalAlignment="Left" Click="btnUpdate_Click"/>

                                <TextBlock x:Name="txtUpdateStatus" Text="Готово к проверке." Foreground="{StaticResource TextSecondary}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <StackPanel Grid.Row="1" Margin="0,15,0,0">
                        <TextBlock x:Name="txtMiniLog" Text="Статус: Ожидание..." Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="5,0,0,10" TextTrimming="CharacterEllipsis"/>

                        <Button x:Name="btnCapture" Content="ЗАПУСТИТЬ ЗАГРУЗКУ" Click="btnCapture_Click" Style="{StaticResource PrimaryButton}" Height="50" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>